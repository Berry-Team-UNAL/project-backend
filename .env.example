# ============================================================
# .env.example — Banneton · Plantilla de variables de entorno
# Copiar a .env y completar valores reales
# ============================================================

# Base de datos PostgreSQL (Docker local)
# El hostname 'postgres' funciona dentro de la red de Docker Compose.
# Para desarrollo local sin Docker: cambiar 'postgres' por 'localhost'.
DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD:-postgres}@postgres:5432/banneton"

# PostgreSQL local (Docker)
POSTGRES_PASSWORD=postgres

# Supabase (si se usa en producción)
NEXT_PUBLIC_SUPABASE_URL="https://TU_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="TU_ANON_KEY"
